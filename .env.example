NODE_ENV=production
PORT=3000
ADMIN_PASSWORD=change-me

# Load the two Claw accounts and their managed mailbox addresses from JSON.
# This is enough for receiving/sending/listening to already-existing mailboxes.
# The JSON file supports: accounts[].name/user/apiKey/users/includePrimary.
CLAW_ACCOUNTS_JSON=./claw_accounts.json

# Optional single-account fallback. Leave empty when CLAW_ACCOUNTS_JSON is used.
# CLAW_API_KEY: Claw API key, usually starts with ck_live_. It is required for
# receiving, sending, replying, reading attachments and WebSocket listeners.
# Get it from Claw Dashboard -> API Keys, or by binding in this app with email code.
CLAW_API_KEY=
# CLAW_DASHBOARD_COOKIE: browser session cookie for https://claw.163.com.
# It is required only for creating/deleting/syncing sub-mailboxes through the
# Dashboard internal API. Open DevTools -> Network on claw.163.com, inspect any
# mailserv-claw-dashboard/api/v1 request, copy the Cookie request header.
CLAW_DASHBOARD_COOKIE=
# CLAW_WORKSPACE_ID: workspace id used by Dashboard mailbox APIs. Get it from
# GET /mailserv-claw-dashboard/api/v1/workspaces response, field result.workspaces[].id.
CLAW_WORKSPACE_ID=
# CLAW_PARENT_MAILBOX_ID: id of the primary/root mailbox under the workspace.
# Get it from GET /mailserv-claw-dashboard/api/v1/mailboxes?workspaceId=<id>,
# usually result.mailbox.id.
CLAW_PARENT_MAILBOX_ID=
# CLAW_ROOT_PREFIX: primary mailbox prefix before @, e.g. lanceagent for
# lanceagent@claw.163.com. New sub-mailboxes become lanceagent.<suffix>@domain.
CLAW_ROOT_PREFIX=
# CLAW_DOMAIN: mailbox domain, normally claw.163.com.
CLAW_DOMAIN=claw.163.com

# Telegram notification defaults. Account-level values in JSON/API can override
# these. TELEGRAM_API_BASE may be a reverse proxy that keeps Telegram Bot API
# path compatibility, e.g. https://tg-proxy.example.com.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org

# Set false if the host cannot keep long-lived WebSocket connections.
ENABLE_WS_LISTENERS=true

DATABASE_PATH=./data/app.db
STATIC_DIR=./dist/web
